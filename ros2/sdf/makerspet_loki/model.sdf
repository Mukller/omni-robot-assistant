<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="makerspet_loki">
    <static>false</static>

    <!-- Base link (chassis) -->
    <link name="base_link">
      <inertial>
        <mass>1.52</mass>
        <inertia>
          <ixx>0.019</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.019</iyy>
          <iyz>0.0</iyz>
          <izz>0.021</izz>
        </inertia>
        <pose>0 0 0 0 0 0</pose>
      </inertial>

      <collision name="base_collision">
        <pose>0 0 0.06 0 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.1</radius>
            <length>0.12</length>
          </cylinder>
        </geometry>
      </collision>

      <visual name="base_visual">
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <uri>model://makerspet_loki/meshes/loki_base.dae</uri>
            <scale>1 1 1</scale>
          </mesh>
        </geometry>
        <material>
          <script>
            <name>Gazebo/DarkGrey</name>
          </script>
        </material>
      </visual>
    </link>

    <!-- Left wheel -->
    <link name="wheel_left_link">
      <pose>0 0.086 0.0375 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>7.031e-05</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>7.031e-05</iyy>
          <iyz>0.0</iyz>
          <izz>1.125e-04</izz>
        </inertia>
      </inertial>
      <collision name="wheel_left_collision">
        <geometry>
          <cylinder>
            <radius>0.0375</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="wheel_left_visual">
        <geometry>
          <cylinder>
            <radius>0.0375</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Black</name>
          </script>
        </material>
      </visual>
    </link>

    <!-- Right wheel -->
    <link name="wheel_right_link">
      <pose>0 -0.086 0.0375 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>7.031e-05</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>7.031e-05</iyy>
          <iyz>0.0</iyz>
          <izz>1.125e-04</izz>
        </inertia>
      </inertial>
      <collision name="wheel_right_collision">
        <geometry>
          <cylinder>
            <radius>0.0375</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>0.5</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="wheel_right_visual">
        <geometry>
          <cylinder>
            <radius>0.0375</radius>
            <length>0.025</length>
          </cylinder>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Black</name>
          </script>
        </material>
      </visual>
    </link>

    <!-- Caster wheel (front) -->
    <link name="caster_link">
      <pose>0.0635 0 0.02 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>8.0e-06</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>8.0e-06</iyy>
          <iyz>0.0</iyz>
          <izz>8.0e-06</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.0</mu>
              <mu2>0.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="caster_visual">
        <geometry>
          <sphere>
            <radius>0.02</radius>
          </sphere>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Grey</name>
          </script>
        </material>
      </visual>
    </link>

    <!-- LiDAR link -->
    <link name="laser">
      <pose>0 0 0.2 0 0 0</pose>
      <inertial>
        <mass>0.125</mass>
        <inertia>
          <ixx>1.0e-04</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>1.0e-04</iyy>
          <iyz>0.0</iyz>
          <izz>1.0e-04</izz>
        </inertia>
      </inertial>
      <visual name="laser_visual">
        <geometry>
          <cylinder>
            <radius>0.04</radius>
            <length>0.04</length>
          </cylinder>
        </geometry>
        <material>
          <script>
            <name>Gazebo/Blue</name>
          </script>
        </material>
      </visual>
      <sensor name="lidar" type="ray">
        <pose>0 0 0 0 0 0</pose>
        <visualize>false</visualize>
        <update_rate>8</update_rate>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle>3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
        <plugin name="gazebo_ros_ray_sensor" filename="libgazebo_ros_ray_sensor.so">
          <ros>
            <remapping>~/out:=scan</remapping>
          </ros>
          <output_type>sensor_msgs/LaserScan</output_type>
          <frame_name>laser</frame_name>
        </plugin>
      </sensor>
    </link>

    <!-- Joints -->
    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <effort>100</effort>
          <velocity>100</velocity>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.001</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <effort>100</effort>
          <velocity>100</velocity>
        </limit>
        <dynamics>
          <damping>0.001</damping>
          <friction>0.001</friction>
        </dynamics>
      </axis>
    </joint>

    <joint name="caster_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_link</child>
    </joint>

    <joint name="laser_joint" type="fixed">
      <parent>base_link</parent>
      <child>laser</child>
    </joint>

    <!-- Differential drive plugin -->
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>30</update_rate>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.172</wheel_separation>
      <wheel_diameter>0.075</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

    <!-- IMU plugin -->
    <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
      <ros>
        <remapping>~/out:=imu/data</remapping>
      </ros>
      <initial_orientation_as_reference>false</initial_orientation_as_reference>
    </plugin>

  </model>
</sdf>
