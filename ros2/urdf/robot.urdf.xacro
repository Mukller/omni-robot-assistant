<?xml version="1.0"?>
<robot name="loki" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="wheel_radius"   value="0.0375"/>
  <xacro:property name="wheel_width"    value="0.027"/>
  <xacro:property name="wheel_base"     value="0.172"/>
  <xacro:property name="robot_height"   value="0.12"/>

  <link name="base_footprint"/>
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.1" length="${robot_height}"/></geometry>
      <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="${robot_height}"/></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </visual>
  </link>
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_left_link"/>
    <origin xyz="0 ${wheel_base/2} 0" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
    </visual>
  </link>
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_right_link"/>
    <origin xyz="0 -${wheel_base/2} 0" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="laser"/>
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser"/>
    <origin xyz="0 0 ${robot_height/2 + 0.02}"/>
  </joint>

  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 0"/>
  </joint>

</robot>
